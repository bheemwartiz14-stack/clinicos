{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@mediclinicpro/db": ["../../packages/db/src/index.ts"],
      "@mediclinicpro/ui/*": ["../../packages/ui/src/*"],
      "@mediclinicpro/utils": ["../../packages/utils/src/index.ts"],
      "@mediclinicpro/validations": ["../../packages/validations/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}