{
  "name": "@mediclinic/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/*": "./src/schema/*/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push --force",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/seed/seed.ts"
  },
  "dependencies": {
    "@mediclinic/logger": "workspace:*",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.38.3",
    "pg": "^8.21.0",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.8.3"
  }
}
