# =========================================
# .env.example
# =========================================
# APP
NODE_ENV=
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_APP_URL=
# DATABASE
DATABASE_URL=postgres://POSTGRES_USER:POSTGRES_PASSWORD@localhost:5432/POSTGRES_DB
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=
# AUTH
JWT_SECRET=
COOKIE_NAME=

# EMAIL (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@mediclinicpro.com

# GOOGLE AUTH
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=

# TOKEN ENCRYPTION (used for encrypting OAuth refresh tokens)
TOKEN_ENCRYPTION_KEY=

# OPENAI
OPENAI_API_KEY=

# DEFAULT USERS
ADMIN_EMAIL=
ADMIN_PASSWORD=

DOCTOR_EMAIL=
DOCTOR_PASSWORD=

NURSE_EMAIL=
NURSE_PASSWORD=

ACCOUNTANT_EMAIL=
ACCOUNTANT_PASSWORD=

RECEPTIONIST_EMAIL=
RECEPTIONIST_PASSWORD=
