{
  "name": "mediclinic-pro",
  "private": true,
  "packageManager": "bun@1.2.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "start:turbo": "turbo start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "deploy:vercel": "bash scripts/deploy-vercel.sh",
    "db:generate": "turbo --filter @mediclinic/db db:generate",
    "db:studio": "turbo --filter @mediclinic/db db:studio",
    "db:push": "turbo --filter @mediclinic/db db:push",
    "db:migrate": "turbo --filter @mediclinic/db db:migrate",
    "db:seed": "turbo --filter @mediclinic/db db:seed"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.77.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.38.3",
    "googleapis": "^171.4.0",
    "googleapis-common": "^8.0.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.468.0",
    "next": "^16.0.0",
    "nodemailer": "^8.0.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.76.0",
    "react-hot-toast": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "workspaces": [
    "apps/web",
    "packages/*"
  ]
}
